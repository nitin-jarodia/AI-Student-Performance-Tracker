# .env.example - Copy to .env and fill in real values.

DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/ai_student_tracker

# Migrations: the API runs `alembic upgrade head` on startup. Set to 1 if you
# already apply migrations in CI and want to skip the in-process upgrade.
# SKIP_AUTO_MIGRATE=0

# JWT (SECRET_KEY MUST be at least 32 characters, rotate in production)
SECRET_KEY=change-me-to-a-random-string-at-least-32-characters-long
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Local development only: seed admin@school.com / Admin@123 on first boot.
# Keep this false in production and create admins through a controlled process.
SEED_DEFAULT_ADMIN=False

# Brute-force protection (slowapi syntax). Dev-friendly defaults shown below —
# tighten in production e.g. "10/minute".
RATE_LIMIT_LOGIN=60/minute
RATE_LIMIT_REFRESH=120/minute

APP_URL=http://localhost:5173
FRONTEND_BASE_URL=http://localhost:5173

# Production: comma-separated frontend URLs for CORS (e.g. https://your-app.onrender.com)
# CORS_ORIGINS=https://your-frontend.example.com

# HttpOnly cookies — set COOKIE_SECURE=true behind HTTPS in production
COOKIE_SECURE=False
COOKIE_SAME_SITE=lax

# Optional Redis (analytics cache). Docker Compose sets redis://redis:6379/0 automatically.
# REDIS_URL=
CACHE_TTL_ANALYTICS=300

OPENAI_API_KEY=

# Email alerts (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=
SMTP_PASSWORD=

# SMS alerts (Twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

ALERT_COOLDOWN_HOURS=24
DEBUG=False
