# .env.example - Copy to .env locally. On Render, set these in the dashboard.
# Required vars marked (REQUIRED).

# (REQUIRED) PostgreSQL — Render Postgres, Neon, Supabase Postgres, or local
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/ai_student_tracker

# (REQUIRED) JWT signing key — min 32 chars. Render can auto-generate via render.yaml.
SECRET_KEY=change-me-to-a-random-string-at-least-32-characters-long

# Migrations: start.sh runs `alembic upgrade head` on Render (SKIP_AUTO_MIGRATE=1 skips in-app duplicate).
SKIP_AUTO_MIGRATE=1

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Local dev only — never enable in production
SEED_DEFAULT_ADMIN=False

RATE_LIMIT_LOGIN=60/minute
RATE_LIMIT_REFRESH=120/minute

# (REQUIRED for production) Your Vercel frontend URL — no trailing slash
FRONTEND_BASE_URL=https://your-app.vercel.app
APP_URL=https://your-app.vercel.app

# Extra CORS origins (comma-separated), e.g. preview deploy URLs
# CORS_ORIGINS=https://your-app-git-main.vercel.app

# QR attendance links shown to students
# PUBLIC_SCAN_BASE_URL=https://your-app.vercel.app/scan

# Cross-origin cookies (Vercel frontend + Render API)
COOKIE_SECURE=true
COOKIE_SAME_SITE=none

# Optional Redis analytics cache (Render Redis or leave empty)
# REDIS_URL=
CACHE_TTL_ANALYTICS=300

# Optional — AI reports / chatbot (https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# Optional — email alerts (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=
SMTP_PASSWORD=

# Optional — SMS alerts (Twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

ALERT_COOLDOWN_HOURS=24
DEBUG=False

# Render injects PORT automatically — do not hardcode in production
# PORT=10000
